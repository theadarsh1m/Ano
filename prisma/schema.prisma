generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id
  nickname    String
  avatar      String?
  bio         String?
  email       String?   @unique
  googleId    String?   @unique
  isAnonymous Boolean   @default(true)
  isOnline    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  lastSeen    DateTime  @default(now())
  messages    Message[]

  // DM relations
  conversationsAsA Conversation[]  @relation("ParticipantA")
  conversationsAsB Conversation[]  @relation("ParticipantB")
  sentDMs          DirectMessage[] @relation("DMSender")

  // Notification relations
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationSender")

  // Friendship relations
  friendshipsAsUser   Friendship[] @relation("FriendshipUser")
  friendshipsAsFriend Friendship[] @relation("FriendshipFriend")
}

model Room {
  id          String   @id
  name        String
  description String?
  type        String   @default("public")
  inviteCode  String?  @unique
  capacity    Int      @default(50)
  createdAt     DateTime       @default(now())
  createdBy     String?
  messages      Message[]
  voiceChannels VoiceChannel[]
}

model VoiceChannel {
  id        String   @id @default(uuid())
  name      String
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  capacity  Int      @default(25)
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id
  content   String
  type      String   @default("text")
  createdAt DateTime @default(now())
  sender    User?    @relation(fields: [senderId], references: [id])
  senderId  String?
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    String
  // Media fields (populated for image/file messages)
  fileUrl   String?
  fileName  String?
  fileSize  Int?
  fileType  String?  // MIME type e.g. "image/png", "application/pdf"
}

model Conversation {
  id             String          @id @default(uuid())
  participantAId String
  participantBId String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  participantA   User            @relation("ParticipantA", fields: [participantAId], references: [id])
  participantB   User            @relation("ParticipantB", fields: [participantBId], references: [id])
  messages       DirectMessage[]

  @@unique([participantAId, participantBId])
}

model DirectMessage {
  id             String       @id @default(uuid())
  content        String
  type           String       @default("text")
  createdAt      DateTime     @default(now())

  senderId       String
  sender         User         @relation("DMSender", fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  // Media fields
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  fileType       String?
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id])
  senderId    String?
  sender      User?    @relation("NotificationSender", fields: [senderId], references: [id])
  
  type        String   // e.g. "friend_request", "friend_accepted", "room_invite", "mention", "system", "activity"
  title       String
  message     String
  isRead      Boolean  @default(false)
  metadata    Json?    // Stores extra info like roomId, conversationId, etc.
  createdAt   DateTime @default(now())
}

model Friendship {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation("FriendshipUser", fields: [userId], references: [id])
  friendId  String
  friend    User     @relation("FriendshipFriend", fields: [friendId], references: [id])
  status    String   // "pending" or "accepted"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, friendId])
}
